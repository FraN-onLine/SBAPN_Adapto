[sub_resource type="Resource" id="Resource_ai_lin23"]
script = ExtResource("1_7hrog")
id = "AI_LIN23"
term = "Matrix Multiplication"
keyword = "dot product rows columns"
definition = "A binary operation that produces a matrix from two matrices, where the element at row i, column j of the product is the dot product of row i of the first matrix and column j of the second matrix."
simple_terms = "Multiplying matrices, where you take the dot product of rows from the first with columns from the second."
examples = ["[ [1, 2], [3, 4] ] * [ [5, 6], [7, 8] ] = [ [1*5 + 2*7, 1*6 + 2*8], [3*5 + 4*7, 3*6 + 4*8] ] = [ [19, 22], [43, 50] ]", "Cannot multiply a 2x3 matrix by a 2x3 matrix."]
accepted_terms = ["Multiply Matrices"]
difficulty = 3
related_to = ["Matrix", "Dimensions", "Dot Product", "Compatibility"]
tof_statement = {
"false": "For matrix multiplication AB, the number of rows in A must equal the number of columns in B.", 
"true": "For matrix multiplication AB, the number of columns in A must equal the number of rows in B."
}
type_of_information = ["definition", "apply"]
metadata/_custom_type_script = "uid://dadne10e1geqd"

[sub_resource type="Resource" id="Resource_ai_lin24"]
script = ExtResource("1_7hrog")
id = "AI_LIN24"
term = "Compatibility for Multiplication"
keyword = "inner dimensions match"
definition = "Two matrices A (m x n) and B (p x q) are compatible for multiplication AB if and only if n = p (the number of columns in A equals the number of rows in B)."
simple_terms = "Matrices can only be multiplied if the 'inner' dimensions match (columns of first = rows of second)."
examples = ["A 2x3 matrix can be multiplied by a 3x4 matrix.", "A 2x3 matrix cannot be multiplied by a 2x3 matrix."]
accepted_terms = ["Matrix Multiplication Compatibility"]
difficulty = 2
related_to = ["Matrix Multiplication", "Dimensions"]
tof_statement = {
"false": "A 3x2 matrix and a 2x5 matrix are not compatible for multiplication in that order.", 
"true": "A 3x2 matrix and a 2x5 matrix are compatible for multiplication in that order."
}
type_of_information = ["definition"]
metadata/_custom_type_script = "uid://dadne10e1geqd"

[sub_resource type="Resource" id="Resource_ai_lin25"]
script = ExtResource("1_7hrog")
id = "AI_LIN25"
term = "Determinant of a Matrix"
keyword = "scalar value"
definition = "A scalar value that can be computed from the elements of a square matrix, providing information about the matrix's properties (e.g., invertibility)."
simple_terms = "A single number calculated from a square matrix that tells us important things about it."
examples = ["Determinant of [ [a, b], [c, d] ] is ad - bc.", "Determinant of [ [1, 2], [3, 4] ] is (1*4) - (2*3) = 4 - 6 = -2."]
