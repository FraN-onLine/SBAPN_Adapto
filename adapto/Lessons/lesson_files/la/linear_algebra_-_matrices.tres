metadata/_custom_type_script = "uid://dadne10e1geqd"

[sub_resource type="Resource" id="Resource_ai_lin29"]
script = ExtResource("1_7hrog")
id = "AI_LIN29"
term = "Row Operations"
keyword = "elementary row operations"
definition = "Basic operations that can be performed on the rows of a matrix without changing the solution set of the corresponding system of linear equations: swapping rows, multiplying a row by a non-zero scalar, or adding a multiple of one row to another."
simple_terms = "Allowed ways to change rows of a matrix to simplify it without changing the answer."
examples = ["Swap Row 1 and Row 2.", "Multiply Row 3 by 5.", "Add 2 times Row 1 to Row 2."]
accepted_terms = ["Elementary Row Operations"]
difficulty = 2
related_to = ["Augmented Matrix", "Gaussian Elimination", "Gauss-Jordan Elimination"]
tof_statement = {
"false": "Multiplying an entire row by zero is a valid row operation.", 
