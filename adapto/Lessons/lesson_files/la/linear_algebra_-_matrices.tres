[sub_resource type="Resource" id="Resource_ai_lin30"]
script = ExtResource("1_7hrog")
id = "AI_LIN30"
term = "Matrix Rank"
keyword = "linearly independent rows/columns"
definition = "The maximum number of linearly independent row vectors or column vectors in a matrix."
simple_terms = "The number of 'essential' rows or columns that can't be made from others."
examples = ["The rank of [ [1, 0], [0, 1] ] is 2.", "The rank of [ [1, 2], [2, 4] ] is 1 because the second row is twice the first."]
accepted_terms = ["Rank of a Matrix"]
difficulty = 3
related_to = ["Matrix", "Linear Independence", "System of Linear Equations"]
tof_statement = {
"false": "The rank of a matrix can be greater than the number of its rows or columns.", 
"true": "The rank of a matrix is less than or equal to the minimum of its number of rows and columns."
}
type_of_information = ["definition"]
