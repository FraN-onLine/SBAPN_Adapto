[sub_resource type="Resource" id="Resource_ai_lin27"]
script = ExtResource("1_7hrog")
id = "AI_LIN27"
term = "Inverse Matrix"
keyword = "A⁻¹"
definition = "For a square matrix A, its inverse A⁻¹ is a matrix such that A * A⁻¹ = A⁻¹ * A = I (the identity matrix)."
simple_terms = "The matrix that, when multiplied by the original matrix, gives the identity matrix."
examples = ["If A = [ [2, 1], [1, 1] ], then A\u207b\u00b9 = [ [1, -1], [-1, 2] ] because A * A\u207b\u00b9 = [ [1, 0], [0, 1] ].", "The inverse of a 2x3 matrix is not defined."]
accepted_terms = ["Matrix Inverse"]
difficulty = 3
related_to = ["Matrix", "Square Matrix", "Invertible Matrix", "Identity Matrix"]
tof_statement = {
"false": "If a matrix A has an inverse A⁻¹, then A * A⁻¹ equals the zero matrix.", 
"true": "If a matrix A has an inverse A⁻¹, then A * A⁻¹ equals the identity matrix."
}
type_of_information = ["definition", "apply"]
metadata/_custom_type_script = "uid://dadne10e1geqd"

[sub_resource type="Resource" id="Resource_ai_lin28"]
script = ExtResource("1_7hrog")
id = "AI_LIN28"
term = "Augmented Matrix"
keyword = "coefficients and constants"
definition = "A matrix formed by combining the coefficient matrix of a system of linear equations with the constant terms, often separated by a vertical line."
simple_terms = "A matrix that combines the coefficients and constants from a system of equations."
examples = ["For the system 2x + 3y = 5 and 4x + 6y = 10, the augmented matrix is [ [2, 3 | 5], [4, 6 | 10] ].", "The augmented matrix for x - y = 1 is [ [1, -1 | 1] ]."]
accepted_terms = ["Augmented System"]
difficulty = 2
related_to = ["Matrix", "System of Linear Equations", "Row Operations"]
tof_statement = {
"false": "An augmented matrix is used to calculate the determinant of a single matrix.", 
