script = ExtResource("1_7hrog")
id = "AI_LIN26"
term = "Invertible Matrix (Non-singular)"
keyword = "inverse exists"
definition = "A square matrix that has a multiplicative inverse, meaning there exists another matrix (its inverse) such that their product is the identity matrix."
simple_terms = "A square matrix that has a 'reciprocal' (its inverse) that multiplies with it to give the identity matrix."
