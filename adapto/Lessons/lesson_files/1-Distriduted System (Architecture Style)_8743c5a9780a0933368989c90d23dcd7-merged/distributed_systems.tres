[sub_resource type="Resource" id="Resource_1"]
script = ExtResource("1_7hrog")
id = "1"
term = "Distributed System"
keyword = "Distributed System"
definition = "A distributed system is a collection of independent computers that appear to its users as a single coherent system."
simple_terms = "Computers working together like one."
examples = ["The internet", "Cloud computing platforms", "Peer-to-peer networks"]
accepted_terms = ["Distributed Computing System"]
difficulty = 1
related_to = ["Concurrency", "Scalability", "Fault Tolerance"]
tof_statement = {
"false": "A distributed system is a single computer with multiple processors.", 
"true": "A distributed system relies on multiple independent computers communicating over a network."
}
type_of_information = ["definition", "explain", "apply"]
metadata/_custom_type_script = "uid://dadne10e1geqd"

[sub_resource type="Resource" id="Resource_2"]
script = ExtResource("1_7hrog")
id = "2"
term = "Resource Sharing"
keyword = "Resource Sharing"
definition = "The ability of a distributed system to allow multiple users or components to access and utilize shared resources, such as hardware, software, or data."
simple_terms = "Letting many people use the same stuff."
examples = ["Shared printers in an office", "Cloud storage for files", "Distributed databases"]
accepted_terms = []
difficulty = 1
related_to = ["Distributed System", "Scalability"]
tof_statement = {
"false": "Resource sharing requires all users to be in the same physical location.", 
"true": "Resource sharing is a key benefit of distributed systems, allowing efficient use of hardware and sof"
}
type_of_information = ["definition", "explain", "apply"]
metadata/_custom_type_script = "uid://dadne10e1geqd"

[sub_resource type="Resource" id="Resource_3"]
script = ExtResource("1_7hrog")
id = "3"
term = "Openness"
keyword = "Openness"
definition = "The ability of a distributed system to be extended and modified, allowing new services and components to be added easily."
simple_terms = "Easy to add new features."
examples = ["Adding new plugins to a software", "Integrating third-party services", "Modular software design"]
accepted_terms = []
difficulty = 2
related_to = ["Distributed System", "Scalability"]
tof_statement = {
"false": "Openness in a distributed system means it is accessible to anyone on the internet.", 
"true": "An open distributed system can easily incorporate new functionalities and services."
}
type_of_information = ["definition", "explain", "apply"]
metadata/_custom_type_script = "uid://dadne10e1geqd"

[sub_resource type="Resource" id="Resource_4"]
script = ExtResource("1_7hrog")
id = "4"
term = "Concurrency"
keyword = "Concurrency"
definition = "The ability of a distributed system to handle multiple tasks or processes executing simultaneously."
simple_terms = "Doing many things at once."
examples = ["Multiple users accessing a website", "Parallel processing in a supercomputer", "Handling multiple requests on a server"]
accepted_terms = []
difficulty = 1
related_to = ["Distributed System", "Scalability", "Threads"]
tof_statement = {
"false": "Concurrency means tasks are executed in a strict sequential order.", 
"true": "Concurrency allows a distributed system to process multiple operations at the same time."
}
type_of_information = ["definition", "explain", "apply"]
metadata/_custom_type_script = "uid://dadne10e1geqd"

[sub_resource type="Resource" id="Resource_5"]
script = ExtResource("1_7hrog")
id = "5"
term = "Scalability"
keyword = "Scalability"
definition = "The ability of a distributed system to handle increasing amounts of work by adding resources."
simple_terms = "Can handle more work by adding more."
examples = ["Adding more servers to a web application", "Increasing database capacity", "Horizontal scaling of services"]
accepted_terms = []
difficulty = 1
related_to = ["Distributed System", "Concurrency", "Resource Sharing"]
tof_statement = {
"false": "Scalable systems can only handle a fixed amount of load.", 
"true": "Scalable systems can handle growth by adding more resources like servers or storage."
}
type_of_information = ["definition", "explain", "apply"]
metadata/_custom_type_script = "uid://dadne10e1geqd"

[sub_resource type="Resource" id="Resource_6"]
script = ExtResource("1_7hrog")
id = "6"
term = "Fault Tolerance"
keyword = "Fault Tolerance"
definition = "The ability of a distributed system to continue operating correctly even if some of its components fail."
simple_terms = "Keeps working even if parts break."
examples = ["Redundant servers", "Data replication", "Failover mechanisms"]
accepted_terms = []
difficulty = 1
related_to = ["Distributed System", "Redundancy"]
tof_statement = {
"false": "Fault tolerance means the system will never experience any failures.", 
"true": "Fault tolerance ensures a distributed system can withstand component failures."
}
type_of_information = ["definition", "explain", "apply"]
metadata/_custom_type_script = "uid://dadne10e1geqd"

[sub_resource type="Resource" id="Resource_7"]
script = ExtResource("1_7hrog")
id = "7"
term = "Transparency"
keyword = "Transparency"
definition = "The property of a distributed system that hides the complexity of distribution from users, making it appear as a single system."
simple_terms = "Hides the complexity of multiple computers."
examples = ["Location transparency", "Access transparency", "Failure transparency"]
accepted_terms = []
difficulty = 2
related_to = ["Distributed System", "Middleware"]
tof_statement = {
"false": "Transparency means all internal workings of the system are visible to the user.", 
"true": "Transparency aims to make a distributed system look and feel like a single, non-distributed system."
}
type_of_information = ["definition", "explain", "apply"]
metadata/_custom_type_script = "uid://dadne10e1geqd"

[sub_resource type="Resource" id="Resource_8"]
script = ExtResource("1_7hrog")
id = "8"
term = "Component"
keyword = "Component"
definition = "A modular unit within a distributed system with well-defined interfaces, which can be replaced or reused."
simple_terms = "A building block with clear connections."
examples = ["A user authentication module", "A database service", "A payment processing module"]
accepted_terms = []
difficulty = 1
related_to = ["Distributed System Architecture", "Modularity"]
tof_statement = {
"false": "Components in a distributed system are tightly coupled and cannot be replaced.", 
"true": "Components in a distributed system are self-contained units with defined interfaces."
}
type_of_information = ["definition", "explain", "apply"]
metadata/_custom_type_script = "uid://dadne10e1geqd"

[sub_resource type="Resource" id="Resource_9"]
script = ExtResource("1_7hrog")
id = "9"
term = "Connector"
keyword = "Connector"
definition = "A communication link or mechanism that connects components in a distributed system, mediating coordination or cooperation."
simple_terms = "The way parts talk to each other."
examples = ["RPC calls", "Message queues", "Network sockets"]
accepted_terms = []
difficulty = 1
related_to = ["Distributed System Architecture", "Communication"]
tof_statement = {
"false": "Connectors are used to store data within components.", 
"true": "Connectors facilitate communication and interaction between components in a distributed system."
}
type_of_information = ["definition", "explain", "apply"]
metadata/_custom_type_script = "uid://dadne10e1geqd"

[sub_resource type="Resource" id="Resource_10"]
script = ExtResource("1_7hrog")
id = "10"
term = "Architectural Styles"
keyword = "Architectural Styles"
