[sub_resource type="Resource" id="Resource_12"]
script = ExtResource("1_7hrog")
id = "12"
term = "Object-Based Architecture"
keyword = "Object-Based Architecture"
definition = "An architectural style where components are based on objects, which encapsulate data and behavior, and interact through method calls."
