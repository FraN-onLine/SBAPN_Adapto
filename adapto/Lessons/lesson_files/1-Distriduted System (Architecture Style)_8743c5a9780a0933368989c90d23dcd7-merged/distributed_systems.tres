metadata/_custom_type_script = "uid://dadne10e1geqd"

[sub_resource type="Resource" id="Resource_33"]
script = ExtResource("1_7hrog")
id = "33"
term = "Thread Pool"
keyword = "Thread Pool"
definition = "A collection of pre-created threads ready to execute tasks, used to improve performance by avoiding the overhead of creating and destroying threads for each request."
simple_terms = "A ready group of threads for tasks."
examples = ["Web server thread pools", "Database connection pools", "Task execution pools"]
accepted_terms = []
difficulty = 2
related_to = ["Thread", "Scalability"]
tof_statement = {
"false": "Thread pools create a new thread for every single request to ensure maximum parallelism.", 
"true": "Thread pools reduce overhead by reusing existing threads instead of creating new ones for every task"
}
type_of_information = ["definition", "explain", "apply"]
metadata/_custom_type_script = "uid://dadne10e1geqd"

[sub_resource type="Resource" id="Resource_34"]
script = ExtResource("1_7hrog")
id = "34"
term = "Naming in Distributed Systems"
keyword = "Naming"
definition = "The process of assigning unique names to entities in a distributed system to facilitate identification, location, and resource sharing."
simple_terms = "Giving unique names to things in a network."
examples = ["Domain Name System (DNS)", "Uniform Resource Locators (URLs)", "File paths"]
accepted_terms = ["Distributed Naming"]
difficulty = 2
related_to = ["Distributed System", "Name Resolution"]
tof_statement = {
"false": "Naming is only relevant for user interfaces and not for system operations.", 
"true": "Naming is crucial for uniquely identifying and locating resources in distributed systems."
}
type_of_information = ["definition", "explain", "apply"]
metadata/_custom_type_script = "uid://dadne10e1geqd"

[sub_resource type="Resource" id="Resource_35"]
script = ExtResource("1_7hrog")
id = "35"
term = "Name Resolution"
keyword = "Name Resolution"
definition = "The process of translating a name into a specific entity or address in a distributed system."
simple_terms = "Finding where something is based on its name."
examples = ["DNS lookup", "Resolving a hostname to an IP address", "Finding a file by its path"]
accepted_terms = []
difficulty = 2
related_to = ["Naming in Distributed Systems", "Distributed System"]
tof_statement = {
"false": "Name resolution is the process of creating new names for entities.", 
"true": "Name resolution is the core function of any naming system, mapping names to entities."
}
type_of_information = ["definition", "explain", "apply"]
metadata/_custom_type_script = "uid://dadne10e1geqd"

[sub_resource type="Resource" id="Resource_36"]
script = ExtResource("1_7hrog")
id = "36"
term = "Location Independence"
keyword = "Location Independence"
definition = "The ability for names in a distributed system to refer to entities regardless of their physical location, allowing entities to move without breaking references."
simple_terms = "Names work even if the thing moves."
examples = ["Using a hostname instead of an IP address", "Cloud object storage references", "Mobile device identification"]
accepted_terms = []
difficulty = 2
related_to = ["Naming in Distributed Systems", "Transparency"]
tof_statement = {
"false": "Location independence means all entities are located in the same physical place.", 
"true": "Location independence ensures that references to entities remain valid even if their network address"
}
type_of_information = ["definition", "explain", "apply"]
metadata/_custom_type_script = "uid://dadne10e1geqd"

[sub_resource type="Resource" id="Resource_37"]
script = ExtResource("1_7hrog")
id = "37"
term = "True Identifiers"
keyword = "True Identifiers"
definition = "Unambiguous identifiers in a distributed system that uniquely refer to at most one entity and are never reused."
simple_terms = "Unique, never-reused IDs."
examples = ["Universally Unique Identifiers (UUIDs)", "Globally Unique Identifiers (GUIDs)", "Unique database primary keys"]
accepted_terms = []
difficulty = 3
related_to = ["Naming in Distributed Systems", "Security"]
tof_statement = {
"false": "True identifiers can be reused after an entity is deleted.", 
"true": "True identifiers guarantee uniqueness and prevent ambiguity in identifying entities."
}
type_of_information = ["definition", "explain", "apply"]
metadata/_custom_type_script = "uid://dadne10e1geqd"

[sub_resource type="Resource" id="Resource_38"]
script = ExtResource("1_7hrog")
id = "38"
term = "Flat Naming"
keyword = "Flat Naming"
definition = "A naming scheme where entities are referred to by identifiers with no inherent meaning or structure, requiring special routing mechanisms."
simple_terms = "Names with no meaning or order."
examples = ["Chord protocol identifiers", "Some peer-to-peer network IDs", "Broadcasting identifiers"]
accepted_terms = []
difficulty = 3
related_to = ["Naming in Distributed Systems", "Distributed Hash Tables (DHTs)"]
tof_statement = {
"false": "Flat naming organizes entities in a hierarchical tree structure.", 
"true": "Flat naming uses unstructured identifiers and relies on routing mechanisms to locate entities."
}
type_of_information = ["definition", "explain", "apply"]
metadata/_custom_type_script = "uid://dadne10e1geqd"

[sub_resource type="Resource" id="Resource_39"]
script = ExtResource("1_7hrog")
id = "39"
term = "Structured Naming"
keyword = "Structured Naming"
definition = "A naming scheme that organizes names into a hierarchical structure, often resembling a tree, with readable path names."
simple_terms = "Names organized like a file system."
examples = ["Domain Name System (DNS)", "File system paths", "LDAP directories"]
accepted_terms = []
difficulty = 2
related_to = ["Naming in Distributed Systems", "Name Resolution"]
tof_statement = {
"false": "Structured naming uses random, meaningless identifiers.", 
"true": "Structured naming uses hierarchical organization, making names more human-readable and easier to res"
}
type_of_information = ["definition", "explain", "apply"]
metadata/_custom_type_script = "uid://dadne10e1geqd"

[sub_resource type="Resource" id="Resource_40"]
script = ExtResource("1_7hrog")
id = "40"
term = "Attribute-Based Naming"
keyword = "Attribute-Based Naming"
definition = "A naming scheme where resources are looked up by evaluating (attribute, value) pairs rather than single distinct names."
simple_terms = "Finding things by describing them."
examples = ["Searching for files by date and size", "LDAP queries", "Resource Description Framework (RDF)"]
accepted_terms = []
difficulty = 3
related_to = ["Naming in Distributed Systems", "Descriptive Lookup"]
tof_statement = {
"false": "Attribute-based naming uses unique identifiers for each resource.", 
"true": "Attribute-based naming allows searching for resources based on their characteristics."
}
type_of_information = ["definition", "explain", "apply"]
metadata/_custom_type_script = "uid://dadne10e1geqd"

[sub_resource type="Resource" id="Resource_41"]
script = ExtResource("1_7hrog")
id = "41"
term = "Message-Oriented Communication"
keyword = "Message-Oriented Communication"
definition = "A communication paradigm where processes exchange information by sending and receiving discrete messages, often asynchronously."
simple_terms = "Talking by sending messages."
examples = ["Message Queuing Systems (MQS)", "AMQP", "Publish-subscribe systems"]
accepted_terms = ["MOM"]
difficulty = 2
related_to = ["Communication", "Middleware", "Asynchronous Processing"]
tof_statement = {
"false": "Message-oriented communication requires senders and receivers to be active simultaneously.", 
"true": "Message-oriented communication decouples senders and receivers in time and space."
}
type_of_information = ["definition", "explain", "apply"]
metadata/_custom_type_script = "uid://dadne10e1geqd"

[sub_resource type="Resource" id="Resource_42"]
script = ExtResource("1_7hrog")
id = "42"
term = "Transient Messaging"
keyword = "Transient Messaging"
definition = "A form of message-oriented communication where messages are lost if the recipient is offline or fails, typically used for direct, high-speed communication."
simple_terms = "Messages that disappear if not received immediately."
examples = ["Sockets", "Message-Passing Interface (MPI)", "Transient Messaging"]
accepted_terms = []
difficulty = 3
related_to = ["Message-Oriented Communication", "Fault Tolerance"]
tof_statement = {
"false": "Transient messaging guarantees message delivery even if the recipient is offline.", 
"true": "Transient messaging prioritizes speed over reliability, as messages may be lost."
}
type_of_information = ["definition", "explain", "apply"]
metadata/_custom_type_script = "uid://dadne10e1geqd"

[sub_resource type="Resource" id="Resource_43"]
script = ExtResource("1_7hrog")
id = "43"
term = "Persistent Messaging"
keyword = "Persistent Messaging"
definition = "A form of message-oriented communication where messages are stored in queues until they can be delivered, ensuring reliability even if recipients are temporarily unavailable."
simple_terms = "Messages that are saved until delivered."
examples = ["Message Queuing Systems (MQS)", "AMQP", "IBM WebSphere MQ"]
accepted_terms = []
difficulty = 2
related_to = ["Message-Oriented Communication", "Fault Tolerance"]
tof_statement = {
"false": "Persistent messaging is as fast as transient messaging.", 
"true": "Persistent messaging ensures message delivery by storing messages in queues until they are received."
}
type_of_information = ["definition", "explain", "apply"]
metadata/_custom_type_script = "uid://dadne10e1geqd"

[sub_resource type="Resource" id="Resource_44"]
script = ExtResource("1_7hrog")
id = "44"
term = "Stream-Oriented Communication"
keyword = "Stream-Oriented Communication"
definition = "A communication method designed for continuous data flow, used for real-time data like audio and video, where timing and synchronization are critical."
simple_terms = "Continuous flow of data, like a video stream."
examples = ["Video streaming", "Audio conferencing", "Real-time data feeds"]
accepted_terms = []
difficulty = 2
related_to = ["Communication", "Quality of Service (QoS)"]
tof_statement = {
"false": "Stream-oriented communication is best for sending discrete, small messages.", 
"true": "Stream-oriented communication is suitable for continuous data transfer where timing is crucial."
}
type_of_information = ["definition", "explain", "apply"]
metadata/_custom_type_script = "uid://dadne10e1geqd"

[sub_resource type="Resource" id="Resource_45"]
script = ExtResource("1_7hrog")
id = "45"
term = "Multicast Communication"
keyword = "Multicast Communication"
definition = "A communication method where a single sender transmits data to multiple receivers simultaneously."
simple_terms = "Sending one message to many people at once."
examples = ["Live video broadcasting", "Stock market data distribution", "Online gaming updates"]
accepted_terms = []
difficulty = 3
related_to = ["Communication", "Application-Level Multicast (ALM)"]
tof_statement = {
"false": "Multicast communication requires a separate message to be sent to each receiver.", 
"true": "Multicast communication allows efficient one-to-many data dissemination."
}
type_of_information = ["definition", "explain", "apply"]
metadata/_custom_type_script = "uid://dadne10e1geqd"

[sub_resource type="Resource" id="Resource_46"]
script = ExtResource("1_7hrog")
id = "46"
term = "Remote Procedure Call RPC"
keyword = "Remote Procedure Call (RPC)"
definition = "A communication protocol that allows a program on one computer to execute a procedure or function on another computer as if it were a local call."
simple_terms = "Calling a function on another computer."
examples = ["gRPC", "Java RMI", "SOAP (historically)"]
accepted_terms = ["RPC"]
difficulty = 2
related_to = ["Communication", "Middleware", "Client Server Architecture"]
tof_statement = {
"false": "RPC requires the client and server to be written in the same programming language.", 
"true": "RPC enables programs to invoke procedures on remote machines seamlessly."
}
type_of_information = ["definition", "explain", "apply"]
metadata/_custom_type_script = "uid://dadne10e1geqd"

[sub_resource type="Resource" id="Resource_47"]
script = ExtResource("1_7hrog")
id = "47"
term = "Client Stub"
keyword = "Client Stub"
definition = "A piece of code on the client side that acts as a proxy for the remote procedure, handling parameter packing and unpacking for RPC."
simple_terms = "Client's helper for remote calls."
examples = ["Generated code by RPC tools", "Proxy objects in RMI", "Client Stub"]
accepted_terms = []
difficulty = 3
related_to = ["Remote Procedure Call (RPC)", "Client Server Architecture"]
tof_statement = {
"false": "The client stub is responsible for executing the remote procedure on the server.", 
"true": "The client stub masks the complexity of network communication during RPC."
}
type_of_information = ["definition", "explain", "apply"]
metadata/_custom_type_script = "uid://dadne10e1geqd"

[sub_resource type="Resource" id="Resource_48"]
script = ExtResource("1_7hrog")
id = "48"
term = "Server Stub"
keyword = "Server Stub"
definition = "A piece of code on the server side that receives RPC requests, unpacks parameters, calls the actual procedure, and packs the results."
simple_terms = "Server's helper for remote calls."
examples = ["Generated code by RPC tools", "Skeleton code in RMI", "Server Stub"]
accepted_terms = []
difficulty = 3
related_to = ["Remote Procedure Call (RPC)", "Client Server Architecture"]
tof_statement = {
"false": "The server stub initiates the RPC request to the client.", 
"true": "The server stub acts as an intermediary between the RPC runtime and the actual server procedure."
}
type_of_information = ["definition", "explain", "apply"]
metadata/_custom_type_script = "uid://dadne10e1geqd"

[sub_resource type="Resource" id="Resource_49"]
script = ExtResource("1_7hrog")
id = "49"
term = "RPC Runtime"
keyword = "RPC Runtime"
definition = "The core component of an RPC system responsible for message transmission, routing, and handling acknowledgements between client and server."
simple_terms = "The engine that makes RPC work."
examples = ["gRPC runtime library", "Java RMI runtime", "RPC Runtime"]
accepted_terms = []
difficulty = 3
related_to = ["Remote Procedure Call (RPC)", "Middleware"]
tof_statement = {
"false": "The RPC runtime only handles the packing and unpacking of parameters.", 
"true": "The RPC runtime manages the underlying communication protocols for RPC calls."
}
type_of_information = ["definition", "explain", "apply"]
metadata/_custom_type_script = "uid://dadne10e1geqd"

[sub_resource type="Resource" id="Resource_50"]
script = ExtResource("1_7hrog")
id = "50"
term = "Synchronous RPC"
keyword = "Synchronous RPC"
definition = "An RPC communication pattern where the client waits for the server's response before continuing its own execution."
simple_terms = "Client waits for server's answer."
examples = ["Standard function calls", "Many traditional RPC implementations", "Synchronous RPC"]
accepted_terms = []
difficulty = 2
related_to = ["Remote Procedure Call (RPC)", "Asynchronous RPC"]
tof_statement = {
"false": "Synchronous RPC allows the client to continue execution immediately after sending a request.", 
"true": "Synchronous RPC simplifies programming by mimicking local function calls, but can lead to blocking."
}
type_of_information = ["definition", "explain", "apply"]
metadata/_custom_type_script = "uid://dadne10e1geqd"

[sub_resource type="Resource" id="Resource_51"]
script = ExtResource("1_7hrog")
id = "51"
term = "Asynchronous RPC"
keyword = "Asynchronous RPC"
definition = "An RPC communication pattern where the client does not wait for the server's response and can continue its execution immediately after sending the request."
simple_terms = "Client sends request and keeps working."
examples = ["Non-blocking I/O operations", "Callback-based RPC frameworks", "Asynchronous RPC"]
accepted_terms = []
difficulty = 3
related_to = ["Remote Procedure Call (RPC)", "Synchronous RPC"]
tof_statement = {
"false": "Asynchronous RPC requires the client to handle responses in the same order they were sent.", 
"true": "Asynchronous RPC improves responsiveness by allowing the client to perform other tasks while waiting"
}
type_of_information = ["definition", "explain", "apply"]
metadata/_custom_type_script = "uid://dadne10e1geqd"

[sub_resource type="Resource" id="Resource_52"]
script = ExtResource("1_7hrog")
id = "52"
term = "One-Way RPC"
keyword = "One-Way RPC"
definition = "A 'fire-and-forget' RPC pattern where the client sends a request but does not expect or wait for any response or acknowledgement."
simple_terms = "Send and don't wait for reply."
examples = ["Logging events", "Sending notifications", "Firewall rule updates"]
accepted_terms = []
difficulty = 3
related_to = ["Remote Procedure Call (RPC)", "Reliability"]
tof_statement = {
"false": "One-way RPC guarantees that the server has processed the request.", 
"true": "One-way RPC offers maximum performance but lacks reliability as there is no confirmation of delivery"
}
type_of_information = ["definition", "explain", "apply"]
metadata/_custom_type_script = "uid://dadne10e1geqd"

[sub_resource type="Resource" id="Resource_53"]
script = ExtResource("1_7hrog")
id = "53"
term = "Layered Protocols"
keyword = "Layered Protocols"
definition = "A set of communication rules organized into layers, where each layer provides services to the layer above it and uses services from the layer below it."
simple_terms = "Rules organized in stacked levels."
examples = ["OSI Model", "TCP/IP model", "HTTP over TCP"]
accepted_terms = []
difficulty = 2
related_to = ["Communication", "OSI Model", "Middleware"]
tof_statement = {
"false": "Layered protocols require each layer to know the details of all other layers.", 
"true": "Layered protocols simplify network communication by breaking it down into manageable layers."
}
type_of_information = ["definition", "explain", "apply"]
metadata/_custom_type_script = "uid://dadne10e1geqd"

[sub_resource type="Resource" id="Resource_54"]
script = ExtResource("1_7hrog")
id = "54"
term = "OSI Model"
keyword = "OSI Model"
definition = "A conceptual framework that standardizes the functions of a telecommunication or computing system in terms of seven layers of abstraction."
simple_terms = "A 7-layer model for network communication."
examples = ["Physical Layer", "Data Link Layer", "Network Layer"]
accepted_terms = ["Open Systems Interconnection Model"]
difficulty = 2
related_to = ["Layered Protocols", "Communication"]
tof_statement = {
"false": "The OSI model is a physical implementation of network hardware.", 
"true": "The OSI model provides a standardized way to understand and design network communication protocols."
}
type_of_information = ["definition", "explain", "apply"]
metadata/_custom_type_script = "uid://dadne10e1geqd"

[sub_resource type="Resource" id="Resource_55"]
script = ExtResource("1_7hrog")
id = "55"
term = "Transport Layer"
keyword = "Transport Layer"
definition = "The fourth layer of the OSI model, responsible for reliable end-to-end data transfer between applications, including ordering and error checking."
simple_terms = "Ensures data arrives correctly."
examples = ["TCP (Transmission Control Protocol)", "UDP (User Datagram Protocol)", "Transport Layer"]
accepted_terms = ["Layer 4"]
difficulty = 2
related_to = ["OSI Model", "TCP", "UDP"]
tof_statement = {
"false": "The Transport Layer is responsible for the physical transmission of data over cables.", 
"true": "The Transport Layer ensures reliable data delivery and manages the connection between applications."
}
type_of_information = ["definition", "explain", "apply"]
metadata/_custom_type_script = "uid://dadne10e1geqd"

[sub_resource type="Resource" id="Resource_56"]
script = ExtResource("1_7hrog")
id = "56"
term = "Application Layer"
keyword = "Application Layer"
definition = "The topmost layer (Layer 7) of the OSI model, where distributed applications reside and interact with the network."
simple_terms = "Where applications use the network."
examples = ["HTTP (Hypertext Transfer Protocol)", "FTP (File Transfer Protocol)", "SMTP (Simple Mail Transfer Protocol)"]
accepted_terms = ["Layer 7"]
difficulty = 1
related_to = ["OSI Model", "Distributed System"]
tof_statement = {
"false": "The Application Layer is concerned with the physical transmission of data.", 
"true": "The Application Layer provides network services directly to end-user applications."
}
type_of_information = ["definition", "explain", "apply"]
metadata/_custom_type_script = "uid://dadne10e1geqd"

[sub_resource type="Resource" id="Resource_57"]
script = ExtResource("1_7hrog")
id = "57"
term = "Middleware Gap"
keyword = "Middleware Gap"
definition = "The space between the Transport layer and the Application layer in modern distributed systems, where middleware services reside."
simple_terms = "The space between transport and apps where middleware fits."
examples = ["RPC services", "Naming services", "Security services"]
accepted_terms = []
difficulty = 3
related_to = ["Middleware", "OSI Model", "Remote Procedure Call (RPC)"]
tof_statement = {
"false": "The 'middleware gap' refers to a physical deficiency in network cables.", 
"true": "Middleware fills the gap in the OSI model to provide higher-level communication services for distrib"
}
type_of_information = ["definition", "explain", "apply"]
metadata/_custom_type_script = "uid://dadne10e1geqd"

[sub_resource type="Resource" id="Resource_58"]
script = ExtResource("1_7hrog")
id = "58"
term = "Naming Services"
keyword = "Naming Services"
definition = "Middleware services that provide a way to look up servers or resources by name rather than by their numerical IP address."
simple_terms = "Services that find things by name."
examples = ["Domain Name System (DNS)", "Service discovery tools", "Directory services"]
accepted_terms = []
difficulty = 2
related_to = ["Middleware", "Naming in Distributed Systems", "DNS"]
tof_statement = {
"false": "Naming services are only used for local network resources.", 
"true": "Naming services abstract away the complexity of IP addresses by allowing users to use human-readable"
}
type_of_information = ["definition", "explain", "apply"]
metadata/_custom_type_script = "uid://dadne10e1geqd"

[sub_resource type="Resource" id="Resource_59"]
script = ExtResource("1_7hrog")
id = "59"
term = "Security"
keyword = "Security"
definition = "In the context of middleware, refers to mechanisms like encryption that protect communication between nodes in a distributed system."
simple_terms = "Protecting data in transit."
examples = ["SSL/TLS encryption", "IPsec", "Secure communication protocols"]
accepted_terms = []
difficulty = 2
related_to = ["Middleware", "Distributed System", "Encryption"]
tof_statement = {
"false": "Security in middleware only applies to user authentication.", 
"true": "Middleware security mechanisms protect data from unauthorized access during network transmission."
}
type_of_information = ["definition", "explain", "apply"]
metadata/_custom_type_script = "uid://dadne10e1geqd"

[sub_resource type="Resource" id="Resource_60"]
script = ExtResource("1_7hrog")
id = "60"
term = "Horizontal Scaling"
keyword = "Horizontal Scaling"
definition = "A method of scaling a system by adding more machines (nodes) to distribute the workload, rather than upgrading existing machines."
simple_terms = "Adding more machines to handle load."
examples = ["Adding more web servers behind a load balancer", "Distributing database read replicas", "Increasing the number of nodes in a cluster"]
