examples = ["OSI Model", "Client-Server Architecture (often layered)", "Three-tier architecture"]
accepted_terms = []
difficulty = 2
related_to = ["Architectural Styles", "OSI Model"]
tof_statement = {
"false": "Layered architecture allows components in any layer to directly communicate with each other.", 
"true": "In a layered architecture, components are arranged in distinct layers, with dependencies flowing dow"
}
