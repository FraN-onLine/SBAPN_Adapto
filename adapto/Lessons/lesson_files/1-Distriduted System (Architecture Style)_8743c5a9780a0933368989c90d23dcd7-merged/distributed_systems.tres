[sub_resource type="Resource" id="Resource_11"]
script = ExtResource("1_7hrog")
id = "11"
term = "Layered Architecture"
keyword = "Layered Architecture"
definition = "An architectural style where components are organized into horizontal layers, with each layer providing services to the layer above it."
