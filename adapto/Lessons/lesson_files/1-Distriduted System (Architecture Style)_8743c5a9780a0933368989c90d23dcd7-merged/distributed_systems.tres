difficulty = 2
related_to = ["Architectural Styles", "Shared Data"]
tof_statement = {
"false": "Data-centered architecture involves direct communication between all components.", 
"true": "In a data-centered architecture, components communicate by reading from and writing to a common data"
}
type_of_information = ["definition", "explain", "apply"]
metadata/_custom_type_script = "uid://dadne10e1geqd"

[sub_resource type="Resource" id="Resource_14"]
script = ExtResource("1_7hrog")
id = "14"
term = "Event-Centered Architecture"
keyword = "Event-Centered Architecture"
definition = "An architectural style where components communicate by reacting to events, often using a publish-subscribe mechanism."
