}
type_of_information = ["definition", "explain", "apply"]
metadata/_custom_type_script = "uid://dadne10e1geqd"

[sub_resource type="Resource" id="Resource_17"]
script = ExtResource("1_7hrog")
id = "17"
term = "Peer-to-Peer P2P Architecture"
keyword = "Peer-to-Peer (P2P) Architecture"
definition = "A distributed system architecture where each node acts as both a client and a server, sharing resources directly with other nodes."
