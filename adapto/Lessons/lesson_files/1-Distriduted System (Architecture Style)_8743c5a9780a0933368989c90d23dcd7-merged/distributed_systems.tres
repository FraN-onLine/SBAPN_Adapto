id = "13"
term = "Data-Centered Architecture"
keyword = "Data-Centered Architecture"
definition = "An architectural style where components interact primarily through a shared data repository or data space."
simple_terms = "System focused on a central data store."
examples = ["Shared database systems", "Tuple spaces", "Content management systems"]
