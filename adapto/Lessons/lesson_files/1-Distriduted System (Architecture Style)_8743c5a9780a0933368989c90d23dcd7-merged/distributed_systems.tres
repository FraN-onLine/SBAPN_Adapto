[sub_resource type="Resource" id="Resource_16"]
script = ExtResource("1_7hrog")
id = "16"
term = "Client Server Architecture"
keyword = "Client Server Architecture"
definition = "A distributed system architecture where clients request services from servers, which provide those services."
simple_terms = "One asks, the other answers."
examples = ["Web browsing (browser client, web server)", "Email (email client, email server)", "Database access (application client, database server)"]
accepted_terms = ["Client-Server Model"]
difficulty = 1
related_to = ["Architectural Styles", "Distributed System"]
