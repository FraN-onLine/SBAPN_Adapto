[sub_resource type="Resource" id="Resource_ai_sig17"]
script = ExtResource("1_7hrog")
id = "AI_SIG17"
term = "Fixation"
keyword = "stuck"
definition = "A persistent focus on an earlier psychosexual stage due to unresolved conflicts or excessive gratification/frustration, leading to specific personality traits in adulthood."
simple_terms = "Getting 'stuck' in a developmental stage."
examples = ["Oral fixation leading to smoking, excessive eating, or nail-biting.", "Anal-retentive personality (stingy, orderly) due to harsh toilet training."]
accepted_terms = ["stage fixation", "psychosexual fixation"]
difficulty = 3
related_to = ["psychosexual stages", "unresolved conflicts", "personality traits", "oral stage", "anal stage"]
tof_statement = {
"false": "Fixation is a conscious choice made in adulthood to focus on childhood experiences.", 
"true": "Fixation occurs when unresolved issues from a psychosexual stage affect adult personality."
}
