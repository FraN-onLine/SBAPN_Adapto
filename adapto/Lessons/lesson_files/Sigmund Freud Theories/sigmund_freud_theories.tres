[sub_resource type="Resource" id="Resource_ai_sig13"]
script = ExtResource("1_7hrog")
id = "AI_SIG13"
term = "Phallic Stage"
keyword = "genitals"
definition = "The third psychosexual stage (3 to 6 years), where the child becomes aware of and focuses on their genitals and the Oedipus/Electra complex."
simple_terms = "Awareness of genitals and attraction to the opposite-sex parent."
examples = ["A boy developing an unconscious desire for his mother and rivalry with his father (Oedipus complex).", "A girl developing an unconscious desire for her father and rivalry with her mother (Electra complex)."]
accepted_terms = ["Oedipus complex", "Electra complex", "phallic phase"]
difficulty = 3
related_to = ["psychosexual stages", "ego", "superego", "identification", "gender identity"]
tof_statement = {
"false": "The phallic stage is primarily concerned with oral pleasures.", 
"true": "The phallic stage is significant for the development of the superego through identification with the same-sex parent."
}
type_of_information = ["definition", "apply"]
metadata/_custom_type_script = "uid://dadne10e1geqd"

[sub_resource type="Resource" id="Resource_ai_sig14"]
script = ExtResource("1_7hrog")
id = "AI_SIG14"
term = "Oedipus Complex"
keyword = "father rivalry"
definition = "During the phallic stage, a boy's unconscious desire for his mother and feelings of rivalry and hostility toward his father."
simple_terms = "Boy wants mom, sees dad as rival."
examples = ["A young boy showing jealousy when his father interacts with his mother.", "A child wanting to 'marry' the parent of the opposite sex."]
accepted_terms = ["Electra complex"]
difficulty = 3
related_to = ["phallic stage", "superego", "identification", "gender development"]
tof_statement = {
"false": "The Oedipus complex is a conscious feeling of affection for all family members.", 
"true": "The Oedipus complex involves a child's unconscious attraction to the parent of the opposite sex and rivalry with the same-sex parent."
}
type_of_information = ["definition", "apply"]
metadata/_custom_type_script = "uid://dadne10e1geqd"

