[sub_resource type="Resource" id="Resource_ai_sig24"]
script = ExtResource("1_7hrog")
id = "AI_SIG24"
term = "Transference"
keyword = "redirected feelings"
definition = "The unconscious redirection of feelings from one person (often a parent) to another (often the therapist) during therapy."
simple_terms = "Treating your therapist like someone from your past."
examples = ["A patient feeling angry at their therapist because the therapist reminds them of a critical parent.", "A patient developing romantic feelings for their therapist."]
accepted_terms = ["therapeutic transference", "emotional redirection"]
difficulty = 3
related_to = ["psychoanalysis", "therapy", "unconscious", "relationships"]
tof_statement = {
"false": "Transference is a conscious and deliberate attempt to manipulate the therapist.", 
"true": "Transference occurs when a patient unconsciously projects feelings about past relationships onto the therapist."
}
type_of_information = ["definition", "apply"]
metadata/_custom_type_script = "uid://dadne10e1geqd"

