difficulty = 2
related_to = ["psychoanalysis", "unconscious", "therapy", "catharsis"]
tof_statement = {
"false": "Free association requires patients to carefully filter their thoughts before speaking.", 
"true": "Free association is a technique used in psychoanalysis to access unconscious material by speaking freely."
}
type_of_information = ["definition", "apply"]
metadata/_custom_type_script = "uid://dadne10e1geqd"

