[sub_resource type="Resource" id="Resource_ai_sig29"]
script = ExtResource("1_7hrog")
id = "AI_SIG29"
term = "Ego Psychology"
keyword = "ego strength"
definition = "A school of psychoanalytic thought that emphasizes the ego's role in development and its ability to adapt to the environment, rather than focusing solely on the id's impulses."
