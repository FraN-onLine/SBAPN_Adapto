[sub_resource type="Resource" id="Resource_ai_sig22"]
script = ExtResource("1_7hrog")
id = "AI_SIG22"
term = "Free Association"
keyword = "say anything"
definition = "A psychoanalytic technique where the patient is encouraged to say whatever comes to mind without censorship, allowing unconscious thoughts to surface."
simple_terms = "Saying whatever pops into your head without holding back."
examples = ["A patient talking about a random memory that suddenly comes to mind during therapy.", "Describing a dream in detail, including seemingly irrelevant thoughts."]
