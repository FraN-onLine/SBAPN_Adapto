"true": "In the oral stage, the infant's pleasure is centered around oral activities like sucking and biting."
}
type_of_information = ["definition", "apply"]
metadata/_custom_type_script = "uid://dadne10e1geqd"

[sub_resource type="Resource" id="Resource_ai_sig12"]
script = ExtResource("1_7hrog")
id = "AI_SIG12"
term = "Anal Stage"
keyword = "toilet training"
definition = "The second psychosexual stage (1 to 3 years), characterized by the child's focus on bowel and bladder control (toilet training)."
simple_terms = "Pleasure from controlling bowel movements."
examples = ["A child learning to use the toilet.", "Resistance or enjoyment during toilet training."]
