[sub_resource type="Resource" id="Resource_ai_sig1"]
script = ExtResource("1_7hrog")
id = "AI_SIG1"
term = "Psychoanalysis"
keyword = "unconscious mind"
definition = "A therapeutic approach and theory developed by Sigmund Freud, focusing on the exploration of the unconscious mind to understand and treat psychological disorders."
simple_terms = "Talking therapy to uncover hidden thoughts."
examples = ["A patient discussing dreams to reveal underlying anxieties.", "Therapist using free association to explore a patient's thoughts."]
accepted_terms = ["Freudian analysis", "depth psychology"]
difficulty = 1
related_to = ["unconscious", "id", "ego", "superego", "defense mechanisms"]
tof_statement = {
"false": "Psychoanalysis primarily focuses on conscious decision-making.", 
"true": "Psychoanalysis aims to bring unconscious material into conscious awareness."
}
type_of_information = ["definition", "apply"]
metadata/_custom_type_script = "uid://dadne10e1geqd"

[sub_resource type="Resource" id="Resource_ai_sig2"]
script = ExtResource("1_7hrog")
id = "AI_SIG2"
term = "Id"
keyword = "pleasure principle"
definition = "The most primitive part of the personality, present from birth, that operates entirely on the pleasure principle, seeking immediate gratification of desires and needs."
simple_terms = "The 'want it now' part of you."
examples = ["A baby crying for food when hungry.", "An impulse to grab a cookie without thinking."]
accepted_terms = ["instinctual drives", "unconscious desires"]
difficulty = 1
related_to = ["ego", "superego", "unconscious", "libido"]
tof_statement = {
"false": "The id operates on the reality principle, delaying gratification.", 
"true": "The id is driven by the desire for immediate pleasure and satisfaction."
}
type_of_information = ["definition", "apply"]
metadata/_custom_type_script = "uid://dadne10e1geqd"

[sub_resource type="Resource" id="Resource_ai_sig3"]
script = ExtResource("1_7hrog")
id = "AI_SIG3"
term = "Ego"
keyword = "reality principle"
definition = "The part of the personality that develops from the id and operates on the reality principle, mediating between the demands of the id, the superego, and the external world."
simple_terms = "The 'planner' or 'decision-maker'."
examples = ["Deciding to save money for a desired item instead of buying it immediately.", "Finding a socially acceptable way to express anger."]
accepted_terms = ["conscious self", "mediator"]
difficulty = 1
related_to = ["id", "superego", "conscious", "defense mechanisms"]
tof_statement = {
"false": "The ego always acts on impulse to fulfill immediate desires.", 
"true": "The ego tries to satisfy the id's desires in realistic and socially acceptable ways."
}
type_of_information = ["definition", "apply"]
metadata/_custom_type_script = "uid://dadne10e1geqd"

[sub_resource type="Resource" id="Resource_ai_sig4"]
script = ExtResource("1_7hrog")
id = "AI_SIG4"
term = "Superego"
keyword = "morality"
definition = "The part of the personality that develops last, representing internalized moral standards and ideals learned from parents and society, striving for perfection."
simple_terms = "Your 'conscience' or 'moral compass'."
examples = ["Feeling guilty after lying.", "Striving to be a good person and follow rules."]
accepted_terms = ["conscience", "moral conscience"]
difficulty = 1
related_to = ["id", "ego", "morality", "internalization"]
tof_statement = {
"false": "The superego is solely focused on seeking immediate pleasure.", 
"true": "The superego judges actions based on internalized moral standards."
}
type_of_information = ["definition", "apply"]
metadata/_custom_type_script = "uid://dadne10e1geqd"

[sub_resource type="Resource" id="Resource_ai_sig5"]
script = ExtResource("1_7hrog")
id = "AI_SIG5"
term = "Unconscious Mind"
keyword = "hidden thoughts"
definition = "The vast reservoir of feelings, thoughts, urges, and memories that are outside of our conscious awareness, significantly influencing behavior."
simple_terms = "Things you don't know you're thinking or feeling."
examples = ["Forgotten childhood memories that affect adult relationships.", "Hidden desires that drive certain behaviors."]
accepted_terms = ["subconscious", "preconscious"]
difficulty = 1
related_to = ["id", "ego", "superego", "dreams", "psychoanalysis"]
tof_statement = {
"false": "The unconscious mind is the same as our conscious awareness.", 
"true": "The unconscious mind contains repressed thoughts and desires that influence behavior."
}
type_of_information = ["definition", "apply"]
metadata/_custom_type_script = "uid://dadne10e1geqd"

[sub_resource type="Resource" id="Resource_ai_sig6"]
script = ExtResource("1_7hrog")
id = "AI_SIG6"
term = "Defense Mechanisms"
keyword = "reduce anxiety"
definition = "Unconscious psychological strategies used to protect a person from anxiety arising from unacceptable thoughts or feelings."
simple_terms = "Mental tricks to avoid feeling bad."
examples = ["Denial: Refusing to accept a painful reality.", "Projection: Attributing one's own unacceptable thoughts to others."]
accepted_terms = ["ego defense mechanisms", "coping mechanisms"]
difficulty = 2
related_to = ["ego", "anxiety", "repression", "denial", "projection"]
tof_statement = {
"false": "Defense mechanisms are always conscious and deliberate actions.", 
"true": "Defense mechanisms operate unconsciously to protect the ego."
}
type_of_information = ["definition", "apply"]
metadata/_custom_type_script = "uid://dadne10e1geqd"

[sub_resource type="Resource" id="Resource_ai_sig7"]
script = ExtResource("1_7hrog")
id = "AI_SIG7"
term = "Repression"
keyword = "forgetting"
definition = "The most fundamental defense mechanism, where unacceptable or painful thoughts, memories, or impulses are pushed into the unconscious."
simple_terms = "Pushing bad memories away so you don't remember them."
examples = ["A person who experienced childhood trauma cannot recall any details of that period.", "Forgetting an embarrassing event."]
accepted_terms = ["motivated forgetting", "unconscious forgetting"]
difficulty = 2
related_to = ["defense mechanisms", "unconscious", "trauma", "memory"]
tof_statement = {
"false": "Repression is a conscious decision to ignore unpleasant feelings.", 
"true": "Repression is an unconscious process of pushing distressing thoughts out of awareness."
}
type_of_information = ["definition", "apply"]
metadata/_custom_type_script = "uid://dadne10e1geqd"

[sub_resource type="Resource" id="Resource_ai_sig8"]
script = ExtResource("1_7hrog")
id = "AI_SIG8"
term = "Denial"
keyword = "refusal"
definition = "A defense mechanism where an individual refuses to accept reality or facts, acting as if a painful event, thought, or feeling did not exist."
simple_terms = "Pretending something bad isn't happening."
examples = ["A smoker refusing to admit that smoking is harmful.", "Someone diagnosed with a serious illness acting as if nothing is wrong."]
accepted_terms = ["reality denial", "refusal of reality"]
difficulty = 1
related_to = ["defense mechanisms", "ego", "anxiety", "reality"]
tof_statement = {
"false": "Denial is about acknowledging and processing difficult emotions.", 
"true": "Denial involves rejecting painful external realities or facts."
}
type_of_information = ["definition", "apply"]
metadata/_custom_type_script = "uid://dadne10e1geqd"

[sub_resource type="Resource" id="Resource_ai_sig9"]
script = ExtResource("1_7hrog")
id = "AI_SIG9"
term = "Projection"
keyword = "blaming"
definition = "A defense mechanism where an individual attributes their own unacceptable thoughts, feelings, or motives to another person."
simple_terms = "Accusing others of what you're secretly doing or thinking."
examples = ["Someone who is cheating on their partner suspects their partner is cheating on them.", "A person who is angry accuses others of being hostile."]
accepted_terms = ["displacement of blame", "attributing motives"]
difficulty = 2
related_to = ["defense mechanisms", "ego", "unconscious", "attribution"]
tof_statement = {
"false": "Projection is the act of taking responsibility for one's own negative feelings.", 
"true": "Projection involves seeing one's own unacceptable traits in others."
}
type_of_information = ["definition", "apply"]
metadata/_custom_type_script = "uid://dadne10e1geqd"

[sub_resource type="Resource" id="Resource_ai_sig10"]
script = ExtResource("1_7hrog")
id = "AI_SIG10"
term = "Psychosexual Stages"
keyword = "child development"
definition = "Freud's theory that personality develops through a series of stages in childhood, each focused on a different erogenous zone, and that fixation at any stage can lead to adult personality traits."
simple_terms = "Stages of development based on pleasure zones."
examples = ["The Oral Stage (0-1 year) focuses on the mouth.", "The Phallic Stage (3-6 years) involves the genitals and the Oedipus complex."]
accepted_terms = ["stages of development", "erogenous zones"]
difficulty = 2
related_to = ["oral stage", "anal stage", "phallic stage", "latency stage", "genital stage", "fixation"]
tof_statement = {
"false": "Freud's psychosexual stages occur only in adulthood.", 
"true": "Freud believed that experiences in childhood psychosexual stages significantly shape adult personality."
}
type_of_information = ["definition", "apply"]
metadata/_custom_type_script = "uid://dadne10e1geqd"

[sub_resource type="Resource" id="Resource_ai_sig11"]
script = ExtResource("1_7hrog")
id = "AI_SIG11"
term = "Oral Stage"
keyword = "mouth"
definition = "The first psychosexual stage (birth to 1 year), where the infant's primary source of pleasure is the mouth (sucking, biting, chewing)."
simple_terms = "Pleasure from the mouth: feeding, sucking."
examples = ["An infant finding comfort in breastfeeding.", "A child who chews on toys."]
accepted_terms = ["oral fixation", "oral phase"]
difficulty = 2
related_to = ["psychosexual stages", "id", "fixation", "libido"]
tof_statement = {
