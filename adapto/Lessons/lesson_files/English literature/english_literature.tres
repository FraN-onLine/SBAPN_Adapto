[sub_resource type="Resource" id="Resource_eng_03"]
script = ExtResource("1_7hrog")
id = "ENG_03"
term = "Iambic Pentameter"
keyword = "rhythm"
definition = "A line of verse with five metrical feet, each consisting of one short (or unstressed) syllable followed by one long (or stressed) syllable."
simple_terms = "Ten syllables per line, alternating unstressed/stressed."
examples = ["da-DUM da-DUM da-DUM", "To be or not to be", "Shall I compare thee"]
accepted_terms = []
difficulty = 2
related_to = ["poetry", "meter", "verse", "rhythm"]
tof_statement = {
"false": "Iambic pentameter is a type of prose writing style.", 
"true": "Iambic pentameter has ten syllables with an alternating stress pattern."
}
type_of_information = ["definition", "explain", "apply"]
metadata/_custom_type_script = "uid://dadne10e1geqd"

