[ext_resource type="Script" uid="uid://7kxviye2bk4p" path="res://adapto/Lessons/lesson.gd" id="2_bkryn"]

[sub_resource type="Resource" id="Resource_ai_aut1"]
script = ExtResource("1_7hrog")
id = "AI_AUT1"
term = "Context-Free Grammar (CFG)"
keyword = "generates"
definition = "A formal grammar where each production rule has a single non-terminal symbol on the left-hand side."
simple_terms = "Rules for creating strings in a language."
examples = ["S -> aSb | \u03b5 (for the language of balanced parentheses)", "S -> 0S1 | \u03b5 (for the language of strings with equal 0s and 1s)"]
difficulty = 1
related_to = ["Formal Languages", "Chomsky Hierarchy", "Pushdown Automata"]
tof_statement = {
"false": "A CFG requires all symbols on the left-hand side of a production rule to be terminals.", 
"true": "A CFG can describe languages where the structure depends on context."
}
type_of_information = ["definition", "apply"]
metadata/_custom_type_script = "uid://dadne10e1geqd"

[sub_resource type="Resource" id="Resource_ai_aut2"]
script = ExtResource("1_7hrog")
id = "AI_AUT2"
term = "Non-terminal Symbol"
keyword = "variable"
definition = "A symbol in a CFG that can be replaced by other symbols (terminals or non-terminals) according to production rules."
simple_terms = "Placeholder that can be expanded."
examples = ["In S -> aSb, 'S' is a non-terminal.", "In A -> BC, 'A', 'B', and 'C' are non-terminals."]
difficulty = 1
related_to = ["Context-Free Grammar (CFG)", "Production Rules"]
tof_statement = {
"false": "Non-terminal symbols can appear on the right-hand side of a production rule but not on the left.", 
"true": "Non-terminal symbols are typically represented by uppercase letters."
}
type_of_information = ["definition"]
metadata/_custom_type_script = "uid://dadne10e1geqd"

[sub_resource type="Resource" id="Resource_ai_aut3"]
script = ExtResource("1_7hrog")
id = "AI_AUT3"
term = "Terminal Symbol"
keyword = "alphabet"
definition = "A symbol in a CFG that cannot be replaced and forms the actual strings of the language."
simple_terms = "The actual characters in the final string."
examples = ["In S -> aSb, 'a' and 'b' are terminal symbols.", "In A -> 0B1, '0' and '1' are terminal symbols."]
difficulty = 1
related_to = ["Context-Free Grammar (CFG)", "Alphabet"]
tof_statement = {
"false": "Terminal symbols can be replaced by non-terminal symbols.", 
"true": "Terminal symbols constitute the alphabet of the language generated by the CFG."
}
type_of_information = ["definition"]
metadata/_custom_type_script = "uid://dadne10e1geqd"

[sub_resource type="Resource" id="Resource_ai_aut4"]
script = ExtResource("1_7hrog")
id = "AI_AUT4"
term = "Production Rule"
keyword = "rewrite"
definition = "A rule in a CFG that specifies how a non-terminal symbol can be replaced by a sequence of terminals and/or non-terminals."
simple_terms = "A substitution rule for non-terminals."
examples = ["S -> aSb", "A -> \u03b5 (epsilon)", "B -> C D"]
difficulty = 1
related_to = ["Context-Free Grammar (CFG)", "Non-terminal Symbol", "Terminal Symbol"]
tof_statement = {
"false": "Production rules in a CFG can have multiple non-terminals on the left-hand side.", 
"true": "A production rule defines a way to derive strings from a grammar."
}
type_of_information = ["definition", "apply"]
metadata/_custom_type_script = "uid://dadne10e1geqd"

[sub_resource type="Resource" id="Resource_ai_aut5"]
script = ExtResource("1_7hrog")
id = "AI_AUT5"
term = "Start Symbol"
keyword = "beginning"
definition = "A special non-terminal symbol in a CFG from which all derivations must begin."
simple_terms = "The starting point of string generation."
examples = ["In S -> aSb | \u03b5, 'S' is the start symbol.", "Often denoted by 'S'."]
difficulty = 1
related_to = ["Context-Free Grammar (CFG)", "Derivation"]
tof_statement = {
"false": "The start symbol must be a terminal symbol.", 
"true": "Every valid string in the language must be derivable starting from the start symbol."
}
type_of_information = ["definition"]
metadata/_custom_type_script = "uid://dadne10e1geqd"

[sub_resource type="Resource" id="Resource_ai_aut6"]
script = ExtResource("1_7hrog")
id = "AI_AUT6"
term = "Derivation"
keyword = "generate"
definition = "A sequence of applications of production rules, starting from the start symbol, to produce a string in the language."
simple_terms = "Step-by-step process to create a string."
examples = ["S => aSb => aaSbb => aa\u03b5bb => aabb", "S => 0S1 => 00S11 => 00\u03b511 => 0011"]
difficulty = 2
related_to = ["Context-Free Grammar (CFG)", "Start Symbol", "Production Rule"]
tof_statement = {
"false": "A derivation can start from any non-terminal symbol.", 
"true": "A derivation shows how a string can be produced by a CFG."
}
type_of_information = ["definition", "apply"]
metadata/_custom_type_script = "uid://dadne10e1geqd"

[sub_resource type="Resource" id="Resource_ai_aut7"]
script = ExtResource("1_7hrog")
id = "AI_AUT7"
term = "Language Generated by a CFG"
keyword = "set"
definition = "The set of all terminal strings that can be derived from the start symbol of the CFG."
simple_terms = "All possible valid strings the grammar can create."
examples = ["L(G) = {a^n b^n | n >= 0} for G: S -> aSb | \u03b5", "L(G) = {0^n 1^n | n >= 0} for G: S -> 0S1 | \u03b5"]
difficulty = 2
related_to = ["Context-Free Grammar (CFG)", "Derivation", "Formal Language"]
tof_statement = {
"false": "The language of a CFG includes all possible strings that can be formed using its non-terminal symbols.", 
"true": "The language of a CFG is a subset of strings formed from its terminal alphabet."
}
type_of_information = ["definition", "apply"]
metadata/_custom_type_script = "uid://dadne10e1geqd"

[sub_resource type="Resource" id="Resource_ai_aut8"]
script = ExtResource("1_7hrog")
id = "AI_AUT8"
term = "Parse Tree"
keyword = "structure"
definition = "A tree that represents the derivation of a terminal string from the start symbol of a CFG."
simple_terms = "A visual representation of how a string is generated."
examples = ["A tree with the root being the start symbol, internal nodes being non-terminals, and leaves being terminals.", "Shows the hierarchical structure of a derivation."]
difficulty = 2
related_to = ["Context-Free Grammar (CFG)", "Derivation", "Parsing"]
tof_statement = {
"false": "The root of a parse tree must be a terminal symbol.", 
"true": "The inorder traversal of the leaves of a parse tree yields the derived string."
}
type_of_information = ["definition", "apply"]
metadata/_custom_type_script = "uid://dadne10e1geqd"

[sub_resource type="Resource" id="Resource_ai_aut9"]
script = ExtResource("1_7hrog")
id = "AI_AUT9"
term = "Ambiguous Grammar"
keyword = "multiple"
definition = "A CFG for which there exists at least one terminal string that can be derived in more than one way (i.e., has multiple distinct parse trees)."
simple_terms = "A grammar that can generate a string in more than one way."
examples = ["E -> E + E | E * E | ( E ) | id (for arithmetic expressions)", "S -> SS | aSb | \u03b5"]
difficulty = 3
related_to = ["Context-Free Grammar (CFG)", "Parse Tree", "Ambiguity"]
tof_statement = {
"false": "All context-free grammars are unambiguous.", 
"true": "An ambiguous grammar can lead to different interpretations of the same string."
}
type_of_information = ["definition", "apply"]
metadata/_custom_type_script = "uid://dadne10e1geqd"

[sub_resource type="Resource" id="Resource_ai_aut10"]
script = ExtResource("1_7hrog")
id = "AI_AUT10"
term = "Unambiguous Grammar"
keyword = "unique"
definition = "A CFG for which every terminal string derivable from the start symbol has exactly one distinct parse tree."
simple_terms = "A grammar that generates each string in only one way."
examples = ["S -> aSb | \u03b5 (generates a^n b^n, which is unambiguous)", "Grammars that define programming language syntax are often designed to be unambiguous."]
difficulty = 3
related_to = ["Context-Free Grammar (CFG)", "Ambiguous Grammar", "Parse Tree"]
tof_statement = {
"false": "An unambiguous grammar can still have ambiguous derivations for some strings.", 
"true": "An unambiguous grammar provides a single, consistent structure for each generated string."
}
type_of_information = ["definition"]
metadata/_custom_type_script = "uid://dadne10e1geqd"

[sub_resource type="Resource" id="Resource_ai_aut11"]
script = ExtResource("1_7hrog")
id = "AI_AUT11"
term = "Epsilon Production"
keyword = "empty"
definition = "A production rule of the form A -> ε, where A is a non-terminal and ε represents the empty string."
simple_terms = "Rule that generates nothing."
examples = ["S -> \u03b5", "A -> \u03b5"]
difficulty = 1
related_to = ["Context-Free Grammar (CFG)", "Production Rule", "Empty String"]
tof_statement = {
"false": "Epsilon productions are only allowed for the start symbol.", 
"true": "Epsilon productions allow a non-terminal to derive the empty string."
}
type_of_information = ["definition", "apply"]
metadata/_custom_type_script = "uid://dadne10e1geqd"

[sub_resource type="Resource" id="Resource_ai_aut12"]
script = ExtResource("1_7hrog")
id = "AI_AUT12"
term = "Empty String (ε)"
keyword = "nothing"
definition = "The string containing no symbols. It is the identity element for string concatenation."
simple_terms = "The absence of characters."
examples = ["Represented by \u03b5 or \u03bb.", "Concatenating a string with \u03b5 does not change the string."]
difficulty = 1
related_to = ["Context-Free Grammar (CFG)", "Epsilon Production"]
tof_statement = {
"false": "The empty string cannot be generated by any CFG.", 
"true": "The empty string can be a member of a language generated by a CFG if there is a derivation for it."
}
type_of_information = ["definition"]
metadata/_custom_type_script = "uid://dadne10e1geqd"

[sub_resource type="Resource" id="Resource_ai_aut13"]
script = ExtResource("1_7hrog")
id = "AI_AUT13"
term = "Unit Production"
keyword = "single"
definition = "A production rule of the form A -> B, where both A and B are non-terminal symbols."
simple_terms = "Rule that replaces one non-terminal with another."
examples = ["A -> B", "S -> A"]
difficulty = 2
related_to = ["Context-Free Grammar (CFG)", "Production Rule"]
tof_statement = {
"false": "Unit productions are essential for generating any language with a CFG.", 
"true": "Unit productions can be removed from a CFG without changing the language it generates."
}
type_of_information = ["definition", "apply"]
metadata/_custom_type_script = "uid://dadne10e1geqd"

[sub_resource type="Resource" id="Resource_ai_aut14"]
script = ExtResource("1_7hrog")
id = "AI_AUT14"
term = "Chomsky Normal Form (CNF)"
keyword = "binary"
definition = "A restricted form of CFG where all production rules are of the form A -> BC or A -> a (where A, B, C are non-terminals and 'a' is a terminal)."
simple_terms = "A standardized format for CFGs."
examples = ["S -> AB", "A -> a"]
difficulty = 3
related_to = ["Context-Free Grammar (CFG)", "Normal Form", "Pushdown Automata"]
tof_statement = {
"false": "A grammar in CNF can have rules like A -> B.", 
"true": "Any CFG can be converted into an equivalent CFG in Chomsky Normal Form."
}
type_of_information = ["definition", "apply"]
metadata/_custom_type_script = "uid://dadne10e1geqd"

[sub_resource type="Resource" id="Resource_ai_aut15"]
script = ExtResource("1_7hrog")
id = "AI_AUT15"
term = "Greibach Normal Form (GNF)"
keyword = "terminal"
definition = "A restricted form of CFG where all production rules are of the form A -> aX1X2...Xn (where A is a non-terminal, 'a' is a terminal, and X_i are non-terminals)."
simple_terms = "Another standardized format for CFGs."
examples = ["S -> aA", "A -> bSB"]
difficulty = 3
related_to = ["Context-Free Grammar (CFG)", "Normal Form", "Pushdown Automata"]
tof_statement = {
"false": "A grammar in GNF can have rules like A -> B.", 
"true": "In GNF, the right-hand side of a production rule must start with a terminal symbol."
}
type_of_information = ["definition", "apply"]
metadata/_custom_type_script = "uid://dadne10e1geqd"

[sub_resource type="Resource" id="Resource_ai_aut16"]
script = ExtResource("1_7hrog")
id = "AI_AUT16"
term = "Pushdown Automaton (PDA)"
keyword = "stack"
definition = "A computational model that recognizes context-free languages. It consists of a finite control, an input tape, and a stack."
simple_terms = "A machine that recognizes CFGs using a stack."
examples = ["Used to check if a string has balanced parentheses.", "Can recognize languages like a^n b^n."]
difficulty = 3
related_to = ["Context-Free Grammar (CFG)", "Formal Language", "Finite Automata"]
tof_statement = {
"false": "A Pushdown Automaton uses a queue to store intermediate states.", 
"true": "A Pushdown Automaton has more computational power than a Finite Automaton."
}
type_of_information = ["definition", "apply"]
metadata/_custom_type_script = "uid://dadne10e1geqd"

[sub_resource type="Resource" id="Resource_ai_aut17"]
script = ExtResource("1_7hrog")
id = "AI_AUT17"
term = "Context-Free Language (CFL)"
keyword = "generated"
definition = "A language that can be generated by a context-free grammar."
simple_terms = "A language recognized by a CFG."
examples = ["The set of all strings with an equal number of 'a's and 'b's.", "The set of all correctly matched and nested parentheses."]
difficulty = 2
related_to = ["Context-Free Grammar (CFG)", "Formal Language", "Pushdown Automaton (PDA)"]
tof_statement = {
"false": "All context-free languages are also regular languages.", 
"true": "All regular languages are also context-free languages."
}
type_of_information = ["definition"]
metadata/_custom_type_script = "uid://dadne10e1geqd"

[sub_resource type="Resource" id="Resource_ai_aut18"]
script = ExtResource("1_7hrog")
id = "AI_AUT18"
term = "Parsing"
keyword = "analyze"
definition = "The process of analyzing a string of symbols to determine its grammatical structure according to a given grammar."
simple_terms = "Figuring out if a string follows the grammar rules."
examples = ["Compilers use parsing to check the syntax of source code.", "Building a parse tree for a given string and grammar."]
difficulty = 2
related_to = ["Context-Free Grammar (CFG)", "Parse Tree", "Compiler Design"]
tof_statement = {
"false": "Parsing is the process of generating strings from a grammar.", 
"true": "Parsing aims to construct a parse tree for an input string."
}
type_of_information = ["definition", "apply"]
metadata/_custom_type_script = "uid://dadne10e1geqd"

[sub_resource type="Resource" id="Resource_ai_aut19"]
script = ExtResource("1_7hrog")
id = "AI_AUT19"
term = "Leftmost Derivation"
keyword = "left"
definition = "A derivation in which the leftmost non-terminal symbol is always chosen to be replaced in each step."
simple_terms = "Always expanding the furthest left variable."
examples = ["S => aSb => aaSbb => aa\u03b5bb => aabb", "This derivation corresponds to a specific type of parse tree."]
difficulty = 2
related_to = ["Context-Free Grammar (CFG)", "Derivation", "Rightmost Derivation"]
tof_statement = {
"false": "A leftmost derivation always results in the same parse tree as a rightmost derivation.", 
"true": "A leftmost derivation of a string can be uniquely represented by its parse tree."
}
type_of_information = ["definition", "apply"]
metadata/_custom_type_script = "uid://dadne10e1geqd"

[sub_resource type="Resource" id="Resource_ai_aut20"]
script = ExtResource("1_7hrog")
id = "AI_AUT20"
term = "Rightmost Derivation"
keyword = "right"
definition = "A derivation in which the rightmost non-terminal symbol is always chosen to be replaced in each step."
simple_terms = "Always expanding the furthest right variable."
examples = ["S => aSb => a(aSb)b => a(a\u03b5b)b => aa\u03b5bb => aabb", "This derivation is also related to parse trees."]
difficulty = 2
related_to = ["Context-Free Grammar (CFG)", "Derivation", "Leftmost Derivation"]
tof_statement = {
"false": "A rightmost derivation is always preferred over a leftmost derivation for practical applications.", 
"true": "A rightmost derivation of a string can be uniquely represented by its parse tree."
}
type_of_information = ["definition", "apply"]
metadata/_custom_type_script = "uid://dadne10e1geqd"

[sub_resource type="Resource" id="Resource_ai_aut21"]
script = ExtResource("1_7hrog")
id = "AI_AUT21"
term = "Nullable Non-terminal"
keyword = "can derive empty"
definition = "A non-terminal symbol that can derive the empty string (ε)."
simple_terms = "A variable that can become nothing."
examples = ["In S -> A, A -> \u03b5, S is nullable because S -> A -> \u03b5.", "If A -> \u03b5, then A is nullable."]
difficulty = 2
related_to = ["Context-Free Grammar (CFG)", "Epsilon Production", "Grammar Simplification"]
tof_statement = {
"false": "Only the start symbol can be nullable.", 
"true": "A nullable non-terminal can potentially lead to derivations of the empty string."
}
type_of_information = ["definition", "apply"]
metadata/_custom_type_script = "uid://dadne10e1geqd"

[sub_resource type="Resource" id="Resource_ai_aut22"]
script = ExtResource("1_7hrog")
id = "AI_AUT22"
term = "Grammar Simplification"
keyword = "remove"
definition = "The process of transforming a CFG into an equivalent CFG with fewer or simpler production rules (e.g., removing useless symbols, epsilon productions, and unit productions)."
simple_terms = "Cleaning up a grammar."
examples = ["Eliminating unreachable non-terminals.", "Removing productions that do not contribute to generating any terminal string."]
difficulty = 3
related_to = ["Context-Free Grammar (CFG)", "Epsilon Production", "Unit Production", "Chomsky Normal Form (CNF)"]
tof_statement = {
"false": "Grammar simplification can change the language generated by the CFG.", 
"true": "Grammar simplification aims to create an equivalent but simpler grammar."
}
type_of_information = ["definition", "apply"]
metadata/_custom_type_script = "uid://dadne10e1geqd"

[sub_resource type="Resource" id="Resource_ai_aut23"]
script = ExtResource("1_7hrog")
id = "AI_AUT23"
term = "Useless Symbol"
keyword = "unproductive"
definition = "A non-terminal or terminal symbol that cannot be part of any derivation of any terminal string from the start symbol."
simple_terms = "A symbol that can't be used to make valid strings."
examples = ["A non-terminal that cannot be reached from the start symbol.", "A non-terminal that cannot derive any terminal string."]
difficulty = 3
related_to = ["Context-Free Grammar (CFG)", "Grammar Simplification", "Derivation"]
tof_statement = {
"false": "All symbols in a CFG are inherently useful for generating strings.", 
"true": "Useless symbols can be removed from a CFG without changing the language it generates."
}
type_of_information = ["definition", "apply"]
metadata/_custom_type_script = "uid://dadne10e1geqd"

[sub_resource type="Resource" id="Resource_ai_aut24"]
script = ExtResource("1_7hrog")
id = "AI_AUT24"
term = "Recursive Production"
keyword = "self-reference"
definition = "A production rule where a non-terminal symbol appears on both the left-hand side and the right-hand side."
simple_terms = "A rule that refers back to itself."
examples = ["S -> aSb", "A -> BC, B -> A"]
difficulty = 1
related_to = ["Context-Free Grammar (CFG)", "Derivation", "Infinite Strings"]
tof_statement = {
"false": "Recursive productions must always be removed for a grammar to be valid.", 
"true": "Recursive productions are essential for generating strings of arbitrary length."
}
type_of_information = ["definition", "apply"]
metadata/_custom_type_script = "uid://dadne10e1geqd"

[sub_resource type="Resource" id="Resource_ai_aut25"]
script = ExtResource("1_7hrog")
id = "AI_AUT25"
term = "Direct Recursion"
keyword = "immediate"
definition = "A type of recursive production where a non-terminal directly produces itself on the right-hand side, e.g., A -> αAβ."
simple_terms = "A non-terminal directly calls itself."
examples = ["S -> aS", "A -> xAy"]
difficulty = 2
related_to = ["Context-Free Grammar (CFG)", "Recursive Production", "Left Recursion"]
tof_statement = {
"false": "Direct recursion is only allowed for the start symbol.", 
"true": "Direct recursion allows for generating sequences of symbols."
}
type_of_information = ["definition", "apply"]
metadata/_custom_type_script = "uid://dadne10e1geqd"

[sub_resource type="Resource" id="Resource_ai_aut26"]
script = ExtResource("1_7hrog")
id = "AI_AUT26"
term = "Indirect Recursion"
keyword = "chain"
definition = "A type of recursive production where a non-terminal can derive itself through a chain of other non-terminals, e.g., A -> B, B -> A."
simple_terms = "A non-terminal calls another, which eventually calls the first."
examples = ["A -> BC, B -> AD, D -> A", "A -> B, B -> C, C -> A"]
difficulty = 3
related_to = ["Context-Free Grammar (CFG)", "Recursive Production", "Grammar Simplification"]
tof_statement = {
"false": "Indirect recursion is always more efficient than direct recursion.", 
"true": "Indirect recursion also allows for generating sequences of symbols, albeit through a more complex path."
}
type_of_information = ["definition", "apply"]
metadata/_custom_type_script = "uid://dadne10e1geqd"

[sub_resource type="Resource" id="Resource_ai_aut27"]
script = ExtResource("1_7hrog")
id = "AI_AUT27"
term = "Left Recursion"
keyword = "starts with"
definition = "A type of direct recursion where a non-terminal on the left-hand side appears as the first symbol on the right-hand side of a production rule (e.g., A -> Ax)."
simple_terms = "A rule where the non-terminal is the very first thing on the right."
examples = ["A -> Ax", "S -> Sa"]
difficulty = 2
related_to = ["Context-Free Grammar (CFG)", "Direct Recursion", "Parsing (Top-Down)"]
tof_statement = {
"false": "Left recursion is always desirable for efficient parsing.", 
"true": "Left recursion can cause infinite loops in top-down parsers."
}
type_of_information = ["definition", "apply"]
metadata/_custom_type_script = "uid://dadne10e1geqd"

[sub_resource type="Resource" id="Resource_ai_aut28"]
script = ExtResource("1_7hrog")
id = "AI_AUT28"
term = "Right Recursion"
keyword = "ends with"
definition = "A type of direct recursion where a non-terminal on the left-hand side appears as the last symbol on the right-hand side of a production rule (e.g., A -> xA)."
simple_terms = "A rule where the non-terminal is the very last thing on the right."
examples = ["A -> xA", "S -> aS"]
difficulty = 2
related_to = ["Context-Free Grammar (CFG)", "Direct Recursion", "Parsing (Bottom-Up)"]
tof_statement = {
"false": "Right recursion is inherently more powerful than left recursion.", 
"true": "Right recursion is generally easier for top-down parsers to handle than left recursion."
}
type_of_information = ["definition", "apply"]
metadata/_custom_type_script = "uid://dadne10e1geqd"

[sub_resource type="Resource" id="Resource_ai_aut29"]
script = ExtResource("1_7hrog")
id = "AI_AUT29"
term = "Context-Free Language Hierarchy"
keyword = "classification"
definition = "CFGs are part of the Chomsky hierarchy, specifically generating Type 2 languages."
simple_terms = "CFGs are one level in a broader classification of languages."
examples = ["Type 0: Recursively Enumerable (Turing Machines)", "Type 1: Context-Sensitive (Linear Bounded Automata)", "Type 2: Context-Free (Pushdown Automata)", "Type 3: Regular (Finite Automata)"]
difficulty = 3
related_to = ["Context-Free Grammar (CFG)", "Chomsky Hierarchy", "Formal Language", "Automata Theory"]
tof_statement = {
"false": "Context-Free Languages are the most powerful class of languages in the Chomsky hierarchy.", 
"true": "Context-Free Languages are more powerful than Regular Languages but less powerful than Context-Sensitive Languages."
}
type_of_information = ["definition"]
metadata/_custom_type_script = "uid://dadne10e1geqd"

[sub_resource type="Resource" id="Resource_ai_aut30"]
script = ExtResource("1_7hrog")
id = "AI_AUT30"
term = "CFG for Arithmetic Expressions"
keyword = "expressions"
definition = "A context-free grammar used to define the syntax of arithmetic expressions, often involving operators like +, -, *, /, and parentheses."
simple_terms = "Rules for writing math formulas."
examples = ["E -> E + T | E - T | T", "T -> T * F | T / F | F", "F -> ( E ) | id"]
difficulty = 3
related_to = ["Context-Free Grammar (CFG)", "Parsing", "Ambiguous Grammar", "Compiler Design"]
tof_statement = {
"false": "A simple CFG like S -> aSb can be used to parse complex arithmetic expressions.", 
"true": "A CFG for arithmetic expressions must handle operator precedence and associativity."
}
type_of_information = ["definition", "apply"]
metadata/_custom_type_script = "uid://dadne10e1geqd"

[resource]
