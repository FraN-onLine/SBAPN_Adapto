[sub_resource type="Resource" id="Resource_ds_syn3"]
script = ExtResource("1_7hrog")
id = "DS_SYN3"
term = "NTP (Network Time Protocol)"
keyword = "accurate time"
definition = "A networking protocol for clock synchronization over packet-switched, variable-latency data networks. It aims to synchronize all participating computers to within a few milliseconds of Coordinated Universal Time (UTC)."
simple_terms = "protocol for keeping computer clocks accurate"
examples = ["Synchronizing servers in a data center", "Ensuring accurate timestamps in logs"]
accepted_terms = ["NTP"]
difficulty = 2
related_to = ["clock synchronization", "UTC", "networking"]
tof_statement = {
