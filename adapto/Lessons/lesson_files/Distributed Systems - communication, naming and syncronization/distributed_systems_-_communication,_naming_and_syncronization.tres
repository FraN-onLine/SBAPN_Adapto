[sub_resource type="Resource" id="Resource_ds_syn4"]
script = ExtResource("1_7hrog")
id = "DS_SYN4"
term = "Logical Clocks"
keyword = "event order"
definition = "A mechanism to order events in a distributed system without relying on physical clocks. Each process maintains a clock, and events are timestamped based on causality."
simple_terms = "ordering events based on cause and effect"
examples = ["Lamport timestamps", "Vector clocks"]
accepted_terms = ["logical time"]
difficulty = 3
related_to = ["clock synchronization", "causality", "distributed systems"]
tof_statement = {
"false": "Logical clocks provide the same wall-clock time as physical clocks.", 
"true": "Logical clocks are crucial for determining the causal order of events in distributed systems where physical clock drift is a concern."
}
type_of_information = ["definition"]
metadata/_custom_type_script = "uid://dadne10e1geqd"

[sub_resource type="Resource" id="Resource_ds_syn5"]
script = ExtResource("1_7hrog")
id = "DS_SYN5"
term = "Lamport Clocks"
keyword = "happened-before"
definition = "A distributed system algorithm that provides a way to assign unique timestamps to events, capturing the 'happened-before' relationship."
simple_terms = "assigning timestamps that show event order"
examples = ["Ordering messages in a distributed system", "Detecting causal relationships"]
accepted_terms = ["Lamport timestamps"]
difficulty = 3
related_to = ["logical clocks", "causality", "event ordering"]
tof_statement = {
"false": "Lamport timestamps can accurately reflect the real-world time difference between events.", 
"true": "Lamport timestamps ensure that if event A happened before event B, then the timestamp of A is less than the timestamp of B."
}
type_of_information = ["definition", "apply"]
metadata/_custom_type_script = "uid://dadne10e1geqd"

[sub_resource type="Resource" id="Resource_ds_syn6"]
script = ExtResource("1_7hrog")
