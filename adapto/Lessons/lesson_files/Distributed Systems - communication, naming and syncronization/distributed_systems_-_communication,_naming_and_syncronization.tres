[sub_resource type="Resource" id="Resource_ds_com1"]
script = ExtResource("1_7hrog")
id = "DS_COM1"
term = "Inter-Process Communication (IPC)"
keyword = "communication"
definition = "Mechanisms that allow different processes to communicate and synchronize their actions."
simple_terms = "processes talking to each other"
examples = ["Pipes", "Message Queues", "Shared Memory"]
accepted_terms = ["IPC", "process communication"]
difficulty = 1
related_to = ["processes", "synchronization"]
tof_statement = {
"false": "IPC is only used for processes running on separate machines.", 
"true": "IPC is essential for enabling collaboration between independent processes."
}
type_of_information = ["definition"]
metadata/_custom_type_script = "uid://dadne10e1geqd"

[sub_resource type="Resource" id="Resource_ds_com2"]
script = ExtResource("1_7hrog")
id = "DS_COM2"
term = "Message Passing"
keyword = "messages"
definition = "A communication paradigm where processes exchange data by sending and receiving messages."
simple_terms = "sending letters between programs"
examples = ["Remote Procedure Calls (RPC)", "Message Queues"]
accepted_terms = ["message passing communication"]
difficulty = 1
related_to = ["IPC", "RPC", "message queues"]
tof_statement = {
"false": "In message passing, the sender and receiver must be tightly coupled and aware of each other's exact location.", 
"true": "Message passing decouples sender and receiver in distributed systems."
}
type_of_information = ["definition"]
metadata/_custom_type_script = "uid://dadne10e1geqd"

[sub_resource type="Resource" id="Resource_ds_com3"]
script = ExtResource("1_7hrog")
id = "DS_COM3"
term = "Remote Procedure Call (RPC)"
keyword = "remote"
definition = "A protocol that allows a program to execute a procedure (subroutine) in another address space (on another computer on a shared network) without the programmer explicitly coding the details of the remote interaction."
simple_terms = "calling a function on another computer"
examples = ["gRPC", "Apache Thrift"]
accepted_terms = ["remote procedure call", "RPC communication"]
difficulty = 2
related_to = ["message passing", "client-server"]
tof_statement = {
"false": "When using RPC, the client must manually serialize and deserialize data for network transmission.", 
"true": "RPC abstracts away the network communication details, making remote function calls look like local ones."
}
type_of_information = ["definition", "apply"]
metadata/_custom_type_script = "uid://dadne10e1geqd"

[sub_resource type="Resource" id="Resource_ds_com4"]
script = ExtResource("1_7hrog")
id = "DS_COM4"
term = "Synchronous Communication"
keyword = "wait"
definition = "A communication model where the sender blocks until the receiver has acknowledged the message, or the message is processed."
simple_terms = "waiting for a reply"
examples = ["Blocking RPC", "Many synchronous message queues"]
accepted_terms = ["blocking communication"]
difficulty = 2
related_to = ["asynchronous communication", "RPC"]
tof_statement = {
"false": "In synchronous communication, the sender can continue its work immediately after sending a message.", 
"true": "Synchronous communication simplifies program logic but can lead to performance bottlenecks."
}
type_of_information = ["definition"]
metadata/_custom_type_script = "uid://dadne10e1geqd"

[sub_resource type="Resource" id="Resource_ds_com5"]
script = ExtResource("1_7hrog")
id = "DS_COM5"
term = "Asynchronous Communication"
keyword = "non-blocking"
definition = "A communication model where the sender does not block after sending a message; it can continue its execution immediately."
simple_terms = "sending without waiting"
examples = ["Message Queues (e.g., RabbitMQ, Kafka)", "Event-driven architectures"]
accepted_terms = ["non-blocking communication"]
difficulty = 2
related_to = ["synchronous communication", "message queues"]
tof_statement = {
"false": "Asynchronous communication requires the sender to wait for the receiver to process the message before proceeding.", 
"true": "Asynchronous communication improves responsiveness and throughput by allowing concurrent operations."
}
type_of_information = ["definition"]
metadata/_custom_type_script = "uid://dadne10e1geqd"

[sub_resource type="Resource" id="Resource_ds_com6"]
script = ExtResource("1_7hrog")
id = "DS_COM6"
term = "Publish-Subscribe (Pub/Sub)"
keyword = "publish"
definition = "A messaging pattern where senders of messages (publishers) do not send messages directly to specific receivers (subscribers). Instead, publishers categorize messages into topics, without knowledge of which subscribers, if any, exist."
simple_terms = "broadcasting messages to interested parties"
examples = ["Kafka topics", "AWS SNS", "Google Cloud Pub/Sub"]
accepted_terms = ["pub-sub", "publish subscribe"]
difficulty = 2
related_to = ["message queues", "decoupling"]
tof_statement = {
"false": "In a publish-subscribe system, publishers must know the exact addresses of all subscribers.", 
"true": "Publish-subscribe systems enable loose coupling between producers and consumers of information."
}
type_of_information = ["definition", "apply"]
metadata/_custom_type_script = "uid://dadne10e1geqd"

[sub_resource type="Resource" id="Resource_ds_com7"]
script = ExtResource("1_7hrog")
id = "DS_COM7"
term = "Message Queue"
keyword = "queue"
definition = "An intermediary component that stores messages sent by a producer until a consumer retrieves them. It decouples producers and consumers."
simple_terms = "a waiting line for messages"
examples = ["RabbitMQ", "ActiveMQ", "Redis Streams"]
accepted_terms = ["MQ", "message broker"]
difficulty = 1
related_to = ["asynchronous communication", "pub/sub", "buffering"]
tof_statement = {
"false": "Message queues require the sender and receiver to be online simultaneously.", 
"true": "Message queues can act as buffers to handle temporary differences in production and consumption rates."
}
type_of_information = ["definition", "apply"]
metadata/_custom_type_script = "uid://dadne10e1geqd"

