[sub_resource type="Resource" id="Resource_ds_syn9"]
script = ExtResource("1_7hrog")
id = "DS_SYN9"
term = "Consensus Problem"
keyword = "agreement"
definition = "The problem of achieving agreement among a group of distributed processes on a single value, even in the presence of failures."
simple_terms = "getting everyone to agree on something"
examples = ["Distributed databases agreeing on transaction commit/abort", "Leader election in a distributed system"]
