[sub_resource type="Resource" id="Resource_ds_syn11"]
script = ExtResource("1_7hrog")
id = "DS_SYN11"
term = "Paxos Consensus Algorithm"
keyword = "distributed agreement"
definition = "A family of protocols for solving consensus in a network of unreliable or failure-prone processes. It's known for its correctness but also its complexity."
simple_terms = "a classic algorithm for distributed agreement"
examples = ["Google's Chubby lock service", "Some distributed databases"]
accepted_terms = ["Paxos"]
difficulty = 4
related_to = ["consensus problem", "distributed systems", "fault tolerance"]
tof_statement = {
"false": "Paxos is a simple algorithm that is easy to implement and debug.", 
"true": "Paxos provides a robust solution for achieving consensus, but its implementation can be challenging to understand and get right."
}
type_of_information = ["definition"]
metadata/_custom_type_script = "uid://dadne10e1geqd"

[sub_resource type="Resource" id="Resource_ds_syn12"]
script = ExtResource("1_7hrog")
id = "DS_SYN12"
term = "Two-Phase Commit (2PC)"
keyword = "transaction commit"
definition = "A distributed transaction coordination protocol that ensures all participants either commit or abort a transaction. It involves a coordinator and participants."
simple_terms = "protocol for ensuring distributed transactions succeed or fail together"
examples = ["Distributed database transactions", "Coordinating updates across multiple services"]
accepted_terms = ["2PC"]
difficulty = 3
related_to = ["distributed transactions", "synchronization", "atomicity"]
tof_statement = {
"false": "2PC is immune to failures of any participant or the coordinator.", 
"true": "Two-Phase Commit aims to provide atomicity for distributed transactions but can be blocking if the coordinator fails."
}
type_of_information = ["definition", "apply"]
metadata/_custom_type_script = "uid://dadne10e1geqd"

[sub_resource type="Resource" id="Resource_ds_syn13"]
script = ExtResource("1_7hrog")
id = "DS_SYN13"
term = "Three-Phase Commit (3PC)"
keyword = "non-blocking commit"
definition = "An extension of the Two-Phase Commit protocol designed to overcome the blocking problem by adding a 'pre-commit' phase."
simple_terms = "an improved version of 2PC to avoid blocking"
examples = ["Rarely used in practice due to complexity and overhead"]
accepted_terms = ["3PC"]
difficulty = 4
related_to = ["two-phase commit", "distributed transactions", "fault tolerance"]
tof_statement = {
"false": "3PC is widely adopted and simpler to implement than 2PC.", 
"true": "Three-Phase Commit aims to be non-blocking under certain failure conditions, unlike 2PC."
}
type_of_information = ["definition"]
metadata/_custom_type_script = "uid://dadne10e1geqd"

[sub_resource type="Resource" id="Resource_ds_syn14"]
script = ExtResource("1_7hrog")
id = "DS_SYN14"
term = "Leader Election"
keyword = "leader"
definition = "The process by which nodes in a distributed system agree on a single node to act as a leader, often responsible for coordinating tasks or managing state."
simple_terms = "choosing one node to be in charge"
examples = ["Raft leader election", "Choosing a master node in a distributed database"]
accepted_terms = ["election"]
difficulty = 2
related_to = ["synchronization", "consensus", "distributed coordination"]
tof_statement = {
"false": "Leader election is only necessary when all nodes are identical and have the same responsibilities.", 
"true": "Leader election is a common mechanism for simplifying coordination in distributed systems."
}
type_of_information = ["definition", "apply"]
metadata/_custom_type_script = "uid://dadne10e1geqd"

[sub_resource type="Resource" id="Resource_ds_syn15"]
script = ExtResource("1_7hrog")
id = "DS_SYN15"
term = "Distributed Transaction"
keyword = "transaction"
definition = "A transaction that operates on multiple distinct data sources or resources, potentially located on different machines in a distributed system."
simple_terms = "a transaction that spans multiple databases or services"
examples = ["Transferring money between accounts in different banks", "Updating data in multiple microservices atomically"]
accepted_terms = ["distributed atomic transaction"]
difficulty = 3
related_to = ["transaction", "atomicity", "two-phase commit"]
tof_statement = {
"false": "Distributed transactions are inherently simpler to manage than local transactions.", 
"true": "Ensuring atomicity in distributed transactions is significantly more challenging than in single-resource transactions."
}
type_of_information = ["definition", "apply"]
metadata/_custom_type_script = "uid://dadne10e1geqd"

[sub_resource type="Resource" id="Resource_ds_syn16"]
script = ExtResource("1_7hrog")
id = "DS_SYN16"
term = "Atomicity"
keyword = "all or nothing"
definition = "The property that a transaction, whether distributed or local, must be executed in its entirety or not at all. It cannot be partially completed."
simple_terms = "either all parts of an operation happen, or none of them do"
examples = ["Ensuring a bank transfer completes fully or not at all", "Atomic updates in a distributed database"]
accepted_terms = ["atomic operation"]
difficulty = 2
related_to = ["distributed transaction", "ACID", "consistency"]
tof_statement = {
"false": "Atomicity means that a transaction can be completed by some participants and aborted by others.", 
"true": "Atomicity guarantees that a transaction will not leave the system in an intermediate, inconsistent state."
}
type_of_information = ["definition"]
metadata/_custom_type_script = "uid://dadne10e1geqd"

[sub_resource type="Resource" id="Resource_ds_syn17"]
script = ExtResource("1_7hrog")
id = "DS_SYN17"
term = "Consistency"
keyword = "valid state"
definition = "The property that a transaction brings the system from one valid state to another. In distributed systems, this can refer to strong consistency, eventual consistency, etc."
simple_terms = "data remains valid and correct"
examples = ["Ensuring all replicas of a database have the same data", "Maintaining data integrity after operations"]
accepted_terms = ["data consistency"]
difficulty = 2
related_to = ["ACID", "distributed systems", "replication"]
tof_statement = {
"false": "All distributed systems must provide strong consistency for all operations.", 
"true": "Consistency in distributed systems often involves trade-offs with availability and partition tolerance (CAP theorem)."
}
type_of_information = ["definition"]
metadata/_custom_type_script = "uid://dadne10e1geqd"

[sub_resource type="Resource" id="Resource_ds_syn18"]
script = ExtResource("1_7hrog")
id = "DS_SYN18"
term = "Eventual Consistency"
keyword = "eventually consistent"
definition = "A consistency model in distributed systems where, if no new updates are made to a given data item, eventually all accesses to that item will return the last updated value."
simple_terms = "data will become consistent over time"
examples = ["Social media feeds", "DNS propagation", "Many NoSQL databases"]
accepted_terms = ["eventual consistency"]
difficulty = 2
related_to = ["consistency", "distributed systems", "CAP theorem"]
tof_statement = {
"false": "In eventually consistent systems, all replicas are updated instantaneously.", 
"true": "Eventual consistency prioritizes availability and partition tolerance, accepting temporary inconsistencies."
}
type_of_information = ["definition", "apply"]
metadata/_custom_type_script = "uid://dadne10e1geqd"

[sub_resource type="Resource" id="Resource_ds_syn19"]
script = ExtResource("1_7hrog")
id = "DS_SYN19"
term = "CAP Theorem"
keyword = "trade-offs"
definition = "A fundamental theorem in distributed systems stating that it is impossible for a distributed data store to simultaneously provide more than two out of the following three guarantees: Consistency, Availability, and Partition Tolerance."
simple_terms = "you can only have two out of three: consistency, availability, partition tolerance"
examples = ["Choosing between CP (Consistency and Partition Tolerance) and AP (Availability and Partition Tolerance) systems"]
accepted_terms = ["CAP"]
difficulty = 3
related_to = ["consistency", "availability", "partition tolerance", "distributed systems"]
tof_statement = {
"false": "The CAP theorem states that a system can always achieve Consistency, Availability, and Partition Tolerance simultaneously.", 
"true": "In the presence of a network partition, a distributed system must choose between maintaining consistency or availability."
}
type_of_information = ["definition", "apply"]
metadata/_custom_type_script = "uid://dadne10e1geqd"

[sub_resource type="Resource" id="Resource_ds_syn20"]
script = ExtResource("1_7hrog")
id = "DS_SYN20"
term = "Partition Tolerance"
keyword = "network partition"
definition = "The ability of a distributed system to continue operating despite network partitions, where communication between different parts of the system is lost."
simple_terms = "system works even if network connections break"
examples = ["Distributed databases that remain available when nodes can't communicate", "Cloud services across different availability zones"]
accepted_terms = ["network partitioning"]
difficulty = 2
related_to = ["CAP theorem", "availability", "consistency", "distributed systems"]
tof_statement = {
"false": "A system can achieve perfect consistency and availability even if network partitions occur.", 
"true": "Partition tolerance is a non-negotiable requirement for most practical distributed systems."
}
type_of_information = ["definition", "apply"]
metadata/_custom_type_script = "uid://dadne10e1geqd"

